apiVersion: kuadrant.io/v1
kind: AuthPolicy
metadata:
  name: {{ object.value.name }}
  namespace: {{ object.value.project }}
spec:
  targetRef:
    group: gateway.networking.k8s.io
    kind: HTTPRoute
    name: {{ object.value.name }}
  rules:
    authentication:
      jwt-keycloak:
        jwt:
          issuerUrl: "{{ object.value.credentials.oidc_issuer }}"
    metadata:
      userInfo:
        identitySource: jwt-keycloak
    response:
      success:
        headers:
{% for header in object.value.introspection.headers %}
{% endfor %}
      unauthorized:
        headers:
          "content-type":
            value: application/json
        body:
          value: |
            {"error": "Unauthorized", "message": "Valid JWT Bearer token required"}
