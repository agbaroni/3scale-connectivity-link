apiVersion: kuadrant.io/v1
kind: AuthPolicy
metadata:
  name: {{ object.value.name }}
  namespace: {{ object.value.project }}
spec:
  targetRef:
    group: gateway.networking.k8s.io
    kind: HTTPRoute
    name: {{ object.value.name }}
  rules:
    authentication:
      simple-user-key:
        apiKey:
          selector:
            matchLabels:
              api_product: {{ object.value.name }}
        credentials:
          queryString:
            name: user_key
    response:
      unauthorized:
        headers:
          "content-type":
            value: application/json
        body:
          value: |
            {"error": "Unauthorized", "message": "Valid JWT Bearer token required"}
